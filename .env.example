# =============================================
# MegaSonic Command Center - Environment Config
# Copy this to .env.local and fill in values
# =============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Calendar + Gemini AI
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_CALENDAR_ID=primary
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Square Payments
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_APPLICATION_ID=your_square_application_id
SQUARE_LOCATION_ID=your_square_location_id
NEXT_PUBLIC_SQUARE_APP_ID=your_square_app_id

# Twilio SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Azure Speech Services (TTS - canadacentral, free tier)
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=canadacentral

# Azure Blob Storage (file uploads - megasonic container)
AZURE_STORAGE_ACCOUNT=your_storage_account_name
AZURE_STORAGE_KEY=your_storage_account_key
AZURE_STORAGE_CONTAINER=megasonic

# =============================================
# Callcentric PBX (Custom WebRTC Engine)
# Account: sonicfeelinc | Number: 17778140621
# Extensions: 100-107 on account 17778140621
# SIP Server: sip.callcentric.com
# WSS Signaling: wss://sip.callcentric.com:8089/ws
# =============================================
PBX_WS_URL=wss://sip.callcentric.com:8089/ws
PBX_ACCOUNT=17778140621
PBX_EXTENSION=100
# Full SIP username = PBX_ACCOUNT + PBX_EXTENSION (e.g. 17778140621100)
# Extension map:
# 100 = CALL NEW (main)
# 101 = HSS Customer Service
# 102 = Calgary Office
# 103 = HSS Field Tech
# 104 = FEELBASSVIP SYSTEM
# 105 = FEELBASSVIP CONF
# 106 = AI
# 107 = FEELBASSVIP Mobile
PBX_PASSWORD=your_callcentric_extension_password
PBX_DISPLAY_NAME=MegaSonic Command Center
PBX_STUN_SERVER=stun:stun.l.google.com:19302
NEXT_PUBLIC_PBX_WS_URL=wss://sip.callcentric.com:8089/ws
NEXT_PUBLIC_PBX_ACCOUNT=17778140621

# App
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
