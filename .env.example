# ==========================================
# MegaSonic Command Center - Environment Config
# Copy this to .env.local and fill in values
# ==========================================

# Supabase (database)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Google Calendar (for vip@feelbass.vip)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_CALENDAR_ID=primary

# Square Payments (MegaSonic App)
# App ID: sq0idp-78wVURzxJlewrxUBAbNJFg
SQUARE_ACCESS_TOKEN=your_square_production_access_token
SQUARE_APPLICATION_ID=sq0idp-78wVURzxJlewrxUBAbNJFg
SQUARE_LOCATION_ID_HSS=LBJ4C01HMM5JH
SQUARE_LOCATION_ID_FEELBASSVIP=LD3AX7708QQMH
SQUARE_LOCATION_ID=LBJ4C01HMM5JH
SQUARE_ENVIRONMENT=production
NEXT_PUBLIC_SQUARE_APP_ID=sq0idp-78wVURzxJlewrxUBAbNJFg

# Twilio SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TWILIO_SMS_TO=+1xxxxxxxxxx

# Azure / Microsoft 365 (M365 calendar + blob storage)
AZURE_TENANT_ID=fa7c0013-654a-41e0-b5f1-9c7f3df17008
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=canadacentral
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string

# Callcentric PBX (VoIP)
# Account: 17778140621
CALLCENTRIC_ACCOUNT=17778140621
CALLCENTRIC_PASSWORD=your_callcentric_password
CALLCENTRIC_SIP_HOST=sip.callcentric.com
# Extensions:
# 100 - CALL NEW
# 101 - HSS Customer Service
# 102 - Calgary Office
# 103 - HSS Field Tech
# 104 - FEELBASSVIP SYSTEM
# 105 - FEELBASSVIP CONF
# 106 - AI
# 107 - FEELBASSVIP Mobile
CALLCENTRIC_EXT_HSS_MAIN=17778140621101
CALLCENTRIC_EXT_FEELBASSVIP=17778140621104
CALLCENTRIC_EXT_AI=17778140621106

# Stripe (optional fallback payments)
STRIPE_SECRET_KEY=your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Email (Resend or SMTP)
RESEND_API_KEY=your_resend_api_key
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@sonicfeel.tech

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth (if using auth)
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Vercel / Deployment
VERCEL_URL=your_vercel_deployment_url
