# ============================================
# MegaSonic Command Center - Environment Config
# Copy this to .env.local and fill in values
# ============================================

# Supabase (database)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Google Calendar (for vip@feelbass.vip)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_CALENDAR_ID=primary

# Square Payments
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_APPLICATION_ID=your_square_application_id
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=sandbox
NEXT_PUBLIC_SQUARE_APP_ID=your_square_app_id

# Twilio SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TWILIO_SMS_TO=+1xxxxxxxxxx

# Azure / Microsoft 365 (M365 calendar + blob storage)
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
M365_CALENDAR_EMAIL=vip@feelbass.vip
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=canadacentral
AZURE_STORAGE_ACCOUNT=your_storage_account_name
AZURE_STORAGE_KEY=your_storage_key
AZURE_STORAGE_CONTAINER=megasonic

# Callcentric / PBX
CALLCENTRIC_ACCOUNT=1777xxxxxxx
CALLCENTRIC_PASSWORD=your_callcentric_password
PBX_SIP_SERVER=callcentric.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
